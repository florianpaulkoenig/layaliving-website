# Supabase — dedicated project for the public website (separate from host-app)
# Project: adscyzgyumuhuzfyrlye (Frankfurt)
NEXT_PUBLIC_SUPABASE_URL=https://adscyzgyumuhuzfyrlye.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only, never expose to browser.
# Used by server actions / route handlers when RLS-bypass is needed.
SUPABASE_SERVICE_ROLE_KEY=

# Lodgify Book-Now-Box (public, hardcoded-ish in code but env-backed for swaps)
NEXT_PUBLIC_LODGIFY_RENTAL_ID=706021
NEXT_PUBLIC_LODGIFY_WEBSITE_ID=599566
NEXT_PUBLIC_LODGIFY_SLUG=layaliving

# Google Places API (New) — for restaurant/venue photos via /api/photo proxy.
# Server-only; never expose to the browser. Restrict to HTTP referrers
# *.vercel.app/* + www.layaliving.ch/* in Google Cloud Console.
GOOGLE_PLACES_API_KEY=
